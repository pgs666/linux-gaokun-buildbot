diff --git a/drivers/input/touchscreen/Kconfig b/drivers/input/touchscreen/Kconfig
index 7d5b72ee0..770f5f4e4 100644
--- a/drivers/input/touchscreen/Kconfig
+++ b/drivers/input/touchscreen/Kconfig
@@ -1424,4 +1424,16 @@ config TOUCHSCREEN_HIMAX_HX83112B
 	  To compile this driver as a module, choose M here: the
 	  module will be called himax_hx83112b.
 
+config TOUCHSCREEN_HIMAX_HX83121A_SPI
+	tristate "Himax hx83121a SPI touchscreen driver"
+	depends on SPI
+	help
+	  Say Y here to enable support for Himax hx83121a touchscreens
+	  connected over SPI.
+
+	  If unsure, say N.
+
+	  To compile this driver as a module, choose M here: the
+	  module will be called himax_hx83121a_spi.
+
