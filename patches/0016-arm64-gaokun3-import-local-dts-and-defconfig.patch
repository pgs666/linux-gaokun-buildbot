+                };
+        };
 
 	wcd938x: audio-codec {
 		compatible = "qcom,wcd9380-codec";
@@ -87,7 +89,8 @@ key-vol-up {
 			linux,can-disable;
 			wakeup-source;
 		};
-
+/*
+		// FIXME: touchpad won't work after detaching
 		switch-mode {
 			label = "Tablet Mode Switch";
 			gpios = <&tlmm 26 GPIO_ACTIVE_HIGH>;
@@ -96,6 +99,52 @@ switch-mode {
 			debounce-interval = <10>;
 			wakeup-source;
 		};
+*/	};
+
+	vreg_avdd_5p5: regulator-avdd-5p5 {
+		compatible = "regulator-fixed";
+
+		regulator-name = "vreg_avdd_5p5";
+		regulator-min-microvolt = <5500000>;
+		regulator-max-microvolt = <5500000>;
+
+		gpio = <&tlmm 52 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&avdd_reg_en>;
+
+		regulator-boot-on;
+	};
+
+	vreg_avee_5p5: regulator-avee-5p5 {
+		compatible = "regulator-fixed";
+
+		regulator-name = "vreg_avee_5p5";
+		regulator-min-microvolt = <5500000>;
+		regulator-max-microvolt = <5500000>;
+
+		gpio = <&tlmm 53 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&avee_reg_en>;
+
+		regulator-boot-on;
