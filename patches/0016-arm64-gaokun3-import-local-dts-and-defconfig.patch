+	zap-shader {
+		memory-region = <&gpu_mem>;
+		firmware-name = "qcom/sc8280xp/HUAWEI/gaokun3/qcdxkmsuc8280.mbn";
+	};
 };
 
 &i2c4 {
-	clock-frequency = <400000>;
+	clock-frequency = <1000000>;
 
 	pinctrl-0 = <&i2c4_default>;
 	pinctrl-names = "default";
 
 	status = "okay";
 
-	touchscreen@4f {
-		compatible = "hid-over-i2c";
-		reg = <0x4f>;
